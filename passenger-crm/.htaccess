# Parse as PHP (cookie bridge for Safari PWA branding).
# На проді файл називається index.html (так зручніше юзеру),
# у dev-репо — Passengers.html. Покриваємо обидва варіанти.
<FilesMatch "^(index|Passengers)\.html$">
    AddHandler application/x-httpd-php .html
</FilesMatch>

# Service Worker — дозвіл на root scope + без кешу
<FilesMatch "sw\.js$">
    Header set Service-Worker-Allowed "/"
    Header set Cache-Control "no-cache"
</FilesMatch>

# Manifest — правильний Content-Type
<FilesMatch "manifest\.php$">
    Header set Cache-Control "public, max-age=86400"
</FilesMatch>

# Кеш для іконок
<FilesMatch "\.(png|ico)$">
    Header set Cache-Control "public, max-age=86400"
</FilesMatch>
