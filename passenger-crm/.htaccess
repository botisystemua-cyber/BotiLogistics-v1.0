# Якщо хтось зайде на директорію /passenger-crm/ без імені файлу —
# Apache віддасть Passengers.html (закриває 404 на директорних URL,
# напр. при PWA-фолбеку Chrome у scope-корінь модуля).
DirectoryIndex Passengers.html

# Parse Passengers.html as PHP (cookie bridge for Safari PWA branding)
<Files "Passengers.html">
    AddHandler application/x-httpd-php .html
</Files>

# Service Worker — дозвіл на root scope + без кешу
<FilesMatch "sw\.js$">
    Header set Service-Worker-Allowed "/"
    Header set Cache-Control "no-cache"
</FilesMatch>

# Manifest — правильний Content-Type
<FilesMatch "manifest\.php$">
    Header set Cache-Control "public, max-age=86400"
</FilesMatch>

# Кеш для іконок
<FilesMatch "\.(png|ico)$">
    Header set Cache-Control "public, max-age=86400"
</FilesMatch>
